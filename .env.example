# Copy to .env (or export directly) and fill in.

# --- LLM provider key (one of these; OpenRouter is what the harness uses) ---
OPENROUTER_API_KEY=sk-or-v1-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Google Sign-In (OAuth) ---
# OAuth 2.0 Client ID (type: Web application) from Google Cloud Console for the
# nxtwave.co.in workspace. The SAME id is used by the browser (Google Identity
# Services) and verified server-side. Add your app origin(s) to the client's
# "Authorized JavaScript origins" (e.g. http://localhost:5173 for dev, and your
# deployed URL). Login is restricted to @nxtwave.co.in accounts.
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# LOCAL DEV ONLY — bypass login entirely (treats you as an admin). NEVER set this
# in a deployed/shared environment.
# AUTH_DISABLED=1

# --- Data storage ---
# Local dev leaves these unset (data lives in the repo's knowledge_base/ + outputs/).
# For a FREE deploy with persistent data, use Turso (libSQL) so the DB survives
# redeploys on an ephemeral host. Create a free DB at https://turso.tech, then:
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-token
# (Alternatively, on a host WITH a persistent disk, set TR_DATA_DIR=/var/data instead.)
