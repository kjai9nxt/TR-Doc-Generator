# Secrets — never commit the API key
.env
*.key

# Generated / runtime
outputs/
logs/
knowledge_base/decks/*.json
knowledge_base/manifest.json
knowledge_base/sync_state.json
knowledge_base/course_structure.json
knowledge_base/_tmp_export.pptx
knowledge_base/learned_rules.json
knowledge_base/regen_events.json
__pycache__/
*.pyc

# Frontend installed deps — never commit
frontend/node_modules/
# NOTE: frontend/dist/ IS committed on purpose. Render's Python build does not run
# a Node build, so the server serves this pre-built output. Rebuild it whenever the
# frontend source changes:  cd frontend && npm run build   (then commit the result).
